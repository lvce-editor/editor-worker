{
  "name": "@lvce-editor/editor-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads  --watch packages/editor-worker/src/editorWorkerMain.ts --outfile=.tmp/dist/dist/editorWorkerMain.js",
    "dev": "node packages/build/src/dev.ts",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "test": "lerna run test",
    "trigger-ci-branches": "bash packages/build/trigger-ci-branches.sh",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^14.0.1",
    "@lvce-editor/eslint-plugin-github-actions": "^14.0.1",
    "@lvce-editor/eslint-plugin-tsconfig": "^14.0.1",
    "eslint": "^10.6.0",
    "knip": "^6.23.0",
    "lerna": "^8.2.4",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3"
  }
}
